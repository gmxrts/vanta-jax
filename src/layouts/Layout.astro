---
import "../styles/global.css";

const {
  title = "VantaJax",
  description = "",
  fullWidth = false,
  isAdmin = false,
  mapLayout = false,
} = Astro.props;

const year = new Date().getFullYear();
---

<html lang="en" data-vj-admin={isAdmin ? "" : undefined}>
  <head>
    <!-- Flash prevention: must be first script, before stylesheets render -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('vanta-theme');
        var system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', saved || system);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" />
    <link rel="icon" href="/favicon.ico" />
    <slot name="head" />
  </head>

  <body class={`min-h-screen antialiased${mapLayout ? ' vj-map-body' : ''}`}>
    <!-- Global header / nav -->
    <header class="border-b border-slate-200">
      <div
        class="mx-auto flex max-w-[1100px] items-center justify-between gap-4 px-4 py-3"
      >
        <!-- Wordmark, always links home -->
        <a href="/" class="flex flex-col items-start gap-0.5" style="align-self:center;">
          <!-- VANTA wordmark — inherits text color for theme, JAX in brand purple -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="28"
            viewBox="0 0 160 28"
            role="img"
            aria-label="VantaJax"
          >
            <text
              x="0"
              y="22"
              font-family="system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif"
              font-weight="800"
              font-size="22"
              letter-spacing="2"
              fill="currentColor"
            >VANTA<tspan fill="#C9A84C">JAX</tspan></text>
          </svg>
          <span class="text-[11px] text-slate-500 leading-none hidden md:block">
            Black-owned · Jacksonville
          </span>
        </a>

        <!-- Primary navigation -->
        <nav class="flex items-center gap-2">
          <!-- Auth buttons — always visible -->
          <a
            id="nav-auth-link"
            href="/login"
            class="rounded-full border border-[#C9A84C] bg-[#C9A84C] px-3 py-1.5 text-[11px] font-semibold text-[#0E0C0A] shadow-sm transition hover:bg-[#8B6914] hover:border-[#8B6914] hover:text-[#FAF8F5]"
            style="display:none"
          >
            Dashboard
          </a>
          <a
            id="nav-login-link"
            href="/login"
            class="rounded-full border border-[#C9A84C] bg-[#C9A84C] px-3 py-1.5 text-[11px] font-semibold text-[#0E0C0A] shadow-sm transition hover:bg-[#8B6914] hover:border-[#8B6914] hover:text-[#FAF8F5]"
          >
            Owner login
          </a>

          <!-- Theme toggle — always visible -->
          {!isAdmin && (
            <button
              id="theme-toggle"
              aria-label="Switch to dark mode"
              style="background:none;border:1px solid var(--border-mid);border-radius:100px;width:34px;height:34px;cursor:pointer;padding:6px;display:inline-flex;align-items:center;justify-content:center;color:inherit;transition:background 150ms ease,border-color 150ms ease;"
              onmouseover="this.style.background='var(--accent-pale)';this.style.borderColor='var(--accent-border)'"
              onmouseout="this.style.background='none';this.style.borderColor='var(--border-mid)'"
            >
              <svg class="theme-icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="theme-icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>
          )}

          <!-- Hamburger — nav links inside -->
          <div id="nav-menu-wrap" style="position:relative;display:inline-flex;align-items:center;">
            <button
              id="nav-hamburger"
              aria-label="Open menu"
              aria-expanded="false"
              style="background:none;border:1px solid var(--border-mid);border-radius:100px;width:34px;height:34px;cursor:pointer;display:inline-flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:0;transition:background 150ms ease,border-color 150ms ease;"
              onmouseover="this.style.background='var(--accent-pale)';this.style.borderColor='var(--accent-border)'"
              onmouseout="if(this.getAttribute('aria-expanded')==='false'){this.style.background='none';this.style.borderColor='var(--border-mid)'}"
            >
              <span style="display:block;width:14px;height:2px;border-radius:1px;background:currentColor;transition:transform 150ms ease,opacity 150ms ease;" class="ham-bar"></span>
              <span style="display:block;width:14px;height:2px;border-radius:1px;background:currentColor;transition:transform 150ms ease,opacity 150ms ease;" class="ham-bar"></span>
              <span style="display:block;width:14px;height:2px;border-radius:1px;background:currentColor;transition:transform 150ms ease,opacity 150ms ease;" class="ham-bar"></span>
            </button>

            <div
              id="nav-dropdown"
              style="display:none;position:absolute;right:0;top:calc(100% + 8px);background:var(--bg-secondary);border:1px solid var(--border-mid);border-radius:14px;box-shadow:0 8px 24px rgba(0,0,0,0.12);padding:6px;min-width:160px;z-index:100;"
            >
              <a href="/about"         class="nav-drop-item">About</a>
              <a href="/businesses"    class="nav-drop-item">Browse</a>
              <a href="/suggest-business" class="nav-drop-item">Suggest a business</a>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main
      class={
        mapLayout
          ? "vj-map-main"
          : fullWidth
          ? "w-full min-h-[calc(100vh-4rem-3rem)] px-4 py-8"
          : "mx-auto min-h-[calc(100vh-4rem-3rem)] max-w-[1100px] px-4 py-8"
      }
    >
      <slot />
    </main>

    <!-- Global footer -->
    <footer style="background:#0C0B13;color:#FAF8F5;">
      <div style="max-width:1120px;margin:0 auto;padding:3rem 2rem 2rem;display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:2.5rem;">
        <div>
          <a href="/" style="display:flex;flex-direction:column;text-decoration:none;line-height:1;margin-bottom:0.875rem;">
            <span style="font-size:1rem;font-weight:700;color:#FAF8F5;letter-spacing:-0.01em;">Vanta <span style="color:#C9A84C;">Collective</span></span>
            <span style="font-size:0.65rem;color:rgba(250,248,245,0.4);margin-top:2px;">Black-owned • Jacksonville, FL</span>
          </a>
          <p style="font-size:0.8rem;font-weight:300;color:rgba(250,248,245,0.45);line-height:1.75;max-width:220px;margin-bottom:1.25rem;">A community-powered directory to discover and support Black-owned businesses — starting in Jacksonville.</p>
          <a href="/" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.75rem;font-weight:500;color:#C9A84C;text-decoration:none;opacity:0.75;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.75'">Platform: VantaJax ↗</a>
        </div>
        <div>
          <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(250,248,245,0.35);margin-bottom:1rem;">Explore</div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li><a href="/businesses" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Browse directory</a></li>
            <li><a href="/suggest-business" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Suggest a business</a></li>
            <li><a href="/about" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">About VantaJax</a></li>
            <li><a href="/login" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Owner login</a></li>
          </ul>
        </div>
        <div>
          <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(250,248,245,0.35);margin-bottom:1rem;">Collective</div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li><a href="/#mission" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Our mission</a></li>
            <li><a href="/#how-it-works" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">How it works</a></li>
            <li><a href="/#waitlist" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Newsletter</a></li>
          </ul>
        </div>
        <div>
          <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(250,248,245,0.35);margin-bottom:1rem;">Legal</div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li><a href="/terms" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Terms</a></li>
            <li><a href="/privacy" style="font-size:0.82rem;color:rgba(250,248,245,0.55);text-decoration:none;" onmouseover="this.style.color='#FAF8F5'" onmouseout="this.style.color='rgba(250,248,245,0.55)'">Privacy</a></li>
          </ul>
        </div>
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.07);padding:1rem 2rem;max-width:1120px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <span style="font-size:0.72rem;color:rgba(250,248,245,0.28);">© {year} Vanta Collective. Built for Jacksonville, FL.</span>
        <div style="display:flex;gap:0.5rem;">
          <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:0.2rem 0.625rem;border-radius:100px;border:1px solid rgba(255,255,255,0.08);color:rgba(250,248,245,0.35);">No ads</span>
          <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:0.2rem 0.625rem;border-radius:100px;border:1px solid rgba(255,255,255,0.08);color:rgba(250,248,245,0.35);">Community-powered</span>
          <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:0.2rem 0.625rem;border-radius:100px;border:1px solid rgba(255,255,255,0.08);color:rgba(250,248,245,0.35);">Always free</span>
        </div>
      </div>
    </footer>
  </body>

  <script is:inline>
    // Auth: check for Supabase session cookie
    (function () {
      const isLoggedIn = document.cookie.split(';').some(function(c) {
        return c.trim().match(/^sb-[^=]+-auth-token/);
      });
      const loginLink = document.getElementById("nav-login-link");
      const authLink = document.getElementById("nav-auth-link");
      if (isLoggedIn) {
        if (loginLink) loginLink.style.display = "none";
        if (authLink) authLink.style.display = "";
      }
    })();

    // Theme toggle
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;

      function updateLabel(theme) {
        btn.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
      }

      updateLabel(document.documentElement.getAttribute('data-theme') || 'light');

      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme') || 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('vanta-theme', next);
        updateLabel(next);
      });
    })();

    // Hamburger menu
    (function () {
      var wrap = document.getElementById('nav-menu-wrap');
      var btn  = document.getElementById('nav-hamburger');
      var drop = document.getElementById('nav-dropdown');
      if (!btn || !drop) return;

      function open() {
        drop.style.display = 'block';
        btn.setAttribute('aria-expanded', 'true');
        btn.style.background = 'var(--accent-pale)';
        btn.style.borderColor = 'var(--accent-border)';
      }
      function close() {
        drop.style.display = 'none';
        btn.setAttribute('aria-expanded', 'false');
        btn.style.background = 'none';
        btn.style.borderColor = 'var(--border-mid)';
      }

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        drop.style.display === 'none' ? open() : close();
      });

      document.addEventListener('click', function (e) {
        if (wrap && !wrap.contains(e.target)) close();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>
</html>
