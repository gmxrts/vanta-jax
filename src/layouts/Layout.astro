---
import "../styles/global.css";

const {
  title = "VantaJax",
  description = "",
  fullWidth = false,
  isAdmin = false,
} = Astro.props;

const year = new Date().getFullYear();
---

<html lang="en" data-vj-admin={isAdmin ? "" : undefined}>
  <head>
    <!-- Flash prevention: must be first script, before stylesheets render -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('vanta-theme');
        var system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', saved || system);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" href="/favicon.ico" />
  </head>

  <body class="min-h-screen antialiased">
    <!-- Global header / nav -->
    <header class="border-b border-slate-200">
      <div
        class="mx-auto flex max-w-[1100px] items-center justify-between gap-4 px-4 py-3"
      >
        <!-- Wordmark, always links home -->
        <a href="/" class="flex flex-col items-start gap-0.5">
          <!-- VANTA wordmark — inherits text color for theme, JAX in brand purple -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="28"
            viewBox="0 0 160 28"
            role="img"
            aria-label="VantaJax"
          >
            <text
              x="0"
              y="22"
              font-family="system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif"
              font-weight="800"
              font-size="22"
              letter-spacing="2"
              fill="currentColor"
            >VANTA<tspan fill="#9333ea">JAX</tspan></text>
          </svg>
          <span class="text-[11px] text-slate-500 leading-none">
            Black-owned • Jacksonville
          </span>
        </a>

        <!-- Primary navigation -->
        <nav class="flex items-center gap-3 text-xs sm:text-sm">
          <a
            href="/about"
            class="text-slate-700 hover:text-purple-700"
          >
            About
          </a>
          <a
            href="/businesses"
            class="text-slate-700 hover:text-purple-700"
          >
            Browse
          </a>
          <a
            href="/suggest-business"
            class="text-slate-700 hover:text-purple-700"
          >
            Suggest
          </a>
          <!-- Auth nav item: shown/hidden by client script -->
          <a
            id="nav-auth-link"
            href="/login"
            class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 shadow-sm transition hover:border-purple-300 hover:text-purple-700"
            style="display:none"
          >
            Dashboard
          </a>
          <a
            id="nav-login-link"
            href="/login"
            class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 shadow-sm transition hover:border-purple-300 hover:text-purple-700"
          >
            Owner login
          </a>
          {!isAdmin && (
            <button
              id="theme-toggle"
              aria-label="Switch to dark mode"
              style="background:none;border:none;cursor:pointer;padding:4px;display:inline-flex;align-items:center;justify-content:center;color:inherit;opacity:0.65;transition:opacity 150ms ease;"
              onmouseover="this.style.opacity='1'"
              onmouseout="this.style.opacity='0.65'"
            >
              <svg class="theme-icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="theme-icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>
          )}
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main
      class={
        fullWidth
          ? "w-full min-h-[calc(100vh-4rem-3rem)] px-4 py-8"
          : "mx-auto min-h-[calc(100vh-4rem-3rem)] max-w-[1100px] px-4 py-8"
      }
    >
      <slot />
    </main>

    <!-- Global footer -->
    <footer class="border-t border-slate-200">
      <div
        class="mx-auto flex max-w-[1100px] flex-col items-center justify-between gap-2 px-4 py-4 text-[11px] text-slate-500 sm:flex-row"
      >
        <span>
          © {year} VantaJax. Built for Jacksonville, FL.
        </span>

        <div class="flex gap-3">
          <a href="/about" class="hover:text-purple-700">
            About
          </a>
          <a href="/businesses" class="hover:text-purple-700">
            Browse
          </a>
          <a href="/suggest-business" class="hover:text-purple-700">
            Suggest
          </a>
        </div>
      </div>
    </footer>
  </body>

  <script is:inline>
    // Auth: check for Supabase session cookie
    (function () {
      const isLoggedIn = document.cookie.split(';').some(function(c) {
        return c.trim().match(/^sb-[^=]+-auth-token/);
      });
      const loginLink = document.getElementById("nav-login-link");
      const authLink = document.getElementById("nav-auth-link");
      if (isLoggedIn) {
        if (loginLink) loginLink.style.display = "none";
        if (authLink) authLink.style.display = "";
      }
    })();

    // Theme toggle
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;

      function updateLabel(theme) {
        btn.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
      }

      // Set initial aria-label to match current theme
      updateLabel(document.documentElement.getAttribute('data-theme') || 'light');

      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme') || 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('vanta-theme', next);
        updateLabel(next);
      });
    })();
  </script>
</html>
