---
import "../styles/global.css";

const {
  title = "VantaJax",
  description = "",
  fullWidth = false
} = Astro.props;

const year = new Date().getFullYear();
---

<html lang="en" class="bg-white text-slate-900">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" href="/favicon.ico" />
  </head>

  <body class="min-h-screen bg-white text-slate-900 antialiased">
    <!-- Global header / nav -->
    <header class="border-b border-slate-200 bg-white">
      <div
        class="mx-auto flex max-w-[1100px] items-center justify-between gap-4 px-4 py-3"
      >
        <!-- Wordmark, always links home -->
        <a href="/" class="flex flex-col items-start gap-0.5">
          <!-- VANTA wordmark — charcoal on light bg, JAX in brand purple -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="28"
            viewBox="0 0 160 28"
            role="img"
            aria-label="VantaJax"
          >
            <text
              x="0"
              y="22"
              font-family="system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif"
              font-weight="800"
              font-size="22"
              letter-spacing="2"
              fill="#0f172a"
            >VANTA<tspan fill="#9333ea">JAX</tspan></text>
          </svg>
          <span class="text-[11px] text-slate-500 leading-none">
            Black-owned • Jacksonville
          </span>
        </a>

        <!-- Primary navigation -->
        <nav class="flex items-center gap-3 text-xs sm:text-sm">
          <a
            href="/about"
            class="text-slate-700 hover:text-purple-700"
          >
            About
          </a>
          <a
            href="/businesses"
            class="text-slate-700 hover:text-purple-700"
          >
            Browse
          </a>
          <a
            href="/suggest-business"
            class="text-slate-700 hover:text-purple-700"
          >
            Suggest
          </a>
          <!-- Auth nav item: shown/hidden by client script -->
          <a
            id="nav-auth-link"
            href="/login"
            class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 shadow-sm transition hover:border-purple-300 hover:text-purple-700"
            style="display:none"
          >
            Dashboard
          </a>
          <a
            id="nav-login-link"
            href="/login"
            class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[11px] font-semibold text-slate-700 shadow-sm transition hover:border-purple-300 hover:text-purple-700"
          >
            Owner login
          </a>
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main
      class={
        fullWidth
          ? "w-full min-h-[calc(100vh-4rem-3rem)] px-4 py-8"
          : "mx-auto min-h-[calc(100vh-4rem-3rem)] max-w-[1100px] px-4 py-8"
      }
    >
      <slot />
    </main>

    <!-- Global footer -->
    <footer class="border-t border-slate-200 bg-white">
      <div
        class="mx-auto flex max-w-[1100px] flex-col items-center justify-between gap-2 px-4 py-4 text-[11px] text-slate-500 sm:flex-row"
      >
        <span>
          © {year} VantaJax. Built for Jacksonville, FL.
        </span>

        <div class="flex gap-3">
          <a href="/about" class="hover:text-purple-700">
            About
          </a>
          <a href="/businesses" class="hover:text-purple-700">
            Browse
          </a>
          <a href="/suggest-business" class="hover:text-purple-700">
            Suggest
          </a>
        </div>
      </div>
    </footer>
  </body>

  <script is:inline>
    // createBrowserClient stores session in cookies — check for sb- auth cookie
    // This is synchronous and fast (no network request needed)
    (function () {
      const isLoggedIn = document.cookie.split(';').some(function(c) {
        return c.trim().match(/^sb-[^=]+-auth-token/);
      });
      const loginLink = document.getElementById("nav-login-link");
      const authLink = document.getElementById("nav-auth-link");
      if (isLoggedIn) {
        if (loginLink) loginLink.style.display = "none";
        if (authLink) authLink.style.display = "";
      }
    })();
  </script>
</html>
