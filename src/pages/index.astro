---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vanta Collective — Jacksonville, FL</title>
<meta name="description" content="Vanta Collective is a community-powered movement to discover, support, and grow Black-owned businesses — starting right here in Jacksonville, FL.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

<style>
/* ─── TOKENS ─── */
:root, [data-theme="light"] {
  --bg:           #FAFAF7;
  --bg-warm:      #F5F0E4;
  --bg-card:      #FFFFFF;
  --text:         #0E0C0A;
  --text-sub:     #6B6355;
  --text-muted:   #9A9080;
  --gold:         #C9A84C;
  --gold-pale:    #FDF6E3;
  --gold-dim:     #8B6914;
  --gold-border:  rgba(201,168,76,0.28);
  --accent:       #7C3CA1;
  --accent-pale:  #F3EBF9;
  --accent-light: #C4A0E8;
  --border:       rgba(14,12,10,0.09);
  --border-mid:   rgba(14,12,10,0.15);
  --chip-bg:      #FFFFFF;
  --chip-text:    #6B6355;
  --badge-v-bg:   #D1FAE5;
  --badge-v-text: #047857;
  --badge-v-brd:  #6EE7B7;
  --badge-c-bg:   #F3EBF9;
  --badge-c-text: #7C3CA1;
  --badge-c-brd:  #C4A0E8;
  --hero-overlay: rgba(245,240,228,0.55);
  --img-filter:   brightness(0.97) saturate(0.92);
}

[data-theme="dark"] {
  --bg:           #0C0B13;
  --bg-warm:      #130F1E;
  --bg-card:      #1A0F2E;
  --text:         #FAF8F5;
  --text-sub:     rgba(250,248,245,0.55);
  --text-muted:   rgba(250,248,245,0.32);
  --gold:         #C9A84C;
  --gold-pale:    rgba(201,168,76,0.1);
  --gold-dim:     #EAD88A;
  --gold-border:  rgba(201,168,76,0.3);
  --accent:       #C4A0E8;
  --accent-pale:  rgba(196,160,232,0.1);
  --accent-light: rgba(196,160,232,0.55);
  --border:       rgba(255,255,255,0.08);
  --border-mid:   rgba(255,255,255,0.14);
  --chip-bg:      rgba(255,255,255,0.07);
  --chip-text:    rgba(250,248,245,0.55);
  --badge-v-bg:   rgba(201,168,76,0.14);
  --badge-v-text: #C9A84C;
  --badge-v-brd:  rgba(201,168,76,0.28);
  --badge-c-bg:   rgba(196,160,232,0.1);
  --badge-c-text: #C4A0E8;
  --badge-c-brd:  rgba(196,160,232,0.25);
  --hero-overlay: rgba(12,11,19,0.62);
  --img-filter:   brightness(0.75) saturate(0.8);
}

/* ─── BASE ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', system-ui, sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; line-height: 1.65; transition: background 0.4s ease, color 0.4s ease; }

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.9rem 2rem;
  background: color-mix(in srgb, var(--bg) 88%, transparent);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  transition: background 0.4s, border-color 0.4s;
}
.nav-logo { display: flex; flex-direction: column; text-decoration: none; line-height: 1; }
.nav-logo-wordmark { font-size: 1.05rem; font-weight: 700; color: var(--text); letter-spacing: -0.01em; transition: color 0.4s; }
.nav-logo-wordmark span { color: var(--gold); }
.nav-logo-sub { font-size: 0.68rem; color: var(--text-sub); margin-top: 2px; transition: color 0.4s; }
.nav-links { display: flex; align-items: center; gap: 0.15rem; list-style: none; }
.nav-links a { font-size: 0.875rem; font-weight: 400; color: var(--text-sub); text-decoration: none; padding: 0.4rem 0.7rem; border-radius: 8px; transition: background 0.15s, color 0.15s; }
.nav-links a:hover { background: var(--gold-pale); color: var(--gold-dim); }
.nav-cta { background: var(--text) !important; color: var(--bg) !important; padding: 0.45rem 1.1rem !important; border-radius: 100px !important; font-weight: 500 !important; transition: opacity 0.2s, transform 0.15s, background 0.4s, color 0.4s !important; }
[data-theme="dark"] .nav-cta { background: var(--gold) !important; color: #0C0B13 !important; }
.nav-cta:hover { opacity: 0.85 !important; transform: translateY(-1px); }
.theme-toggle { background: none; border: 1.5px solid var(--border-mid); border-radius: 100px; width: 36px; height: 36px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; color: var(--text-sub); transition: border-color 0.2s, background 0.2s; flex-shrink: 0; }
.theme-toggle:hover { background: var(--gold-pale); border-color: var(--gold-border); }

/* ─── HERO ─── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 0 0 5rem;
  overflow: hidden;
}
.hero-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 60%;
  filter: var(--img-filter);
  transition: filter 0.4s;
  z-index: 0;
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.12) 35%, rgba(0,0,0,0.62) 68%, rgba(0,0,0,0.88) 100%);
  transition: opacity 0.4s;
}
[data-theme="light"] .hero-overlay {
  background: linear-gradient(to bottom, rgba(245,240,228,0.15) 0%, rgba(20,15,10,0.1) 35%, rgba(10,8,5,0.7) 70%, rgba(14,12,10,0.93) 100%);
}
.hero-inner { position: relative; z-index: 2; max-width: 960px; padding: 0 2rem; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 1.5rem;
  opacity: 0; animation: fadeUp 0.6s 0.2s ease forwards;
}
.hero-eyebrow::before { content: ''; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; display: inline-block; }
.hero-headline {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 6.5vw, 6rem);
  font-weight: 900; line-height: 1.03;
  color: #fff; margin-bottom: 1.5rem;
  opacity: 0; animation: fadeUp 0.75s 0.32s ease forwards;
  text-shadow: 0 2px 24px rgba(0,0,0,0.35);
}
.hero-headline em { font-style: italic; color: var(--gold); }
.hero-sub {
  font-size: clamp(1rem, 1.8vw, 1.15rem); font-weight: 300;
  color: rgba(255,255,255,0.8); max-width: 520px; line-height: 1.8; margin-bottom: 2.25rem;
  opacity: 0; animation: fadeUp 0.75s 0.46s ease forwards;
}
.hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.875rem; opacity: 0; animation: fadeUp 0.75s 0.58s ease forwards; }
.btn-primary {
  background: var(--gold); color: #0C0B13;
  font-family: 'DM Sans', sans-serif; font-size: 0.9rem; font-weight: 600;
  padding: 0.825rem 2rem; border-radius: 100px; border: none;
  cursor: pointer; text-decoration: none;
  transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s; display: inline-block;
}
.btn-primary:hover { opacity: 0.88; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,168,76,0.35); }
.btn-outline-white {
  background: rgba(255,255,255,0.1); color: #fff;
  font-family: 'DM Sans', sans-serif; font-size: 0.9rem; font-weight: 400;
  padding: 0.825rem 1.625rem; border-radius: 100px; border: 1.5px solid rgba(255,255,255,0.3);
  cursor: pointer; text-decoration: none;
  transition: background 0.2s, border-color 0.2s, transform 0.15s; display: inline-block;
  backdrop-filter: blur(8px);
}
.btn-outline-white:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.5); transform: translateY(-1px); }
.hero-pillars { display: flex; flex-wrap: wrap; gap: 0.625rem; margin-top: 3rem; opacity: 0; animation: fadeUp 0.75s 0.7s ease forwards; }
.pillar-chip {
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
  border-radius: 100px; padding: 0.4rem 0.9rem;
  font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.8);
  display: flex; align-items: center; gap: 0.4rem;
  backdrop-filter: blur(8px);
}
.pillar-chip .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
.hero-credit { position: absolute; bottom: 1rem; right: 1.25rem; z-index: 3; font-size: 0.65rem; color: rgba(255,255,255,0.35); font-weight: 400; }
.hero-credit a { color: rgba(255,255,255,0.35); text-decoration: none; }
.hero-credit a:hover { color: rgba(255,255,255,0.6); }

/* ─── MARQUEE ─── */
.marquee-wrap { background: #0C0B13; overflow: hidden; padding: 0.875rem 0; }
.marquee-track { display: flex; animation: marquee 30s linear infinite; white-space: nowrap; }
.marquee-item { display: inline-flex; align-items: center; gap: 1rem; padding: 0 1.75rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.13em; text-transform: uppercase; color: rgba(201,168,76,0.55); }
.marquee-sep { display: inline-block; width: 3px; height: 3px; background: var(--gold); border-radius: 50%; opacity: 0.35; }
@keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ─── SHARED ─── */
.section-wrap { max-width: 1120px; margin: 0 auto; padding: 6rem 2rem; }
.eyebrow { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.71rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 1.125rem; transition: color 0.4s; }
[data-theme="dark"] .eyebrow { color: var(--gold); }
.eyebrow::before { content: ''; width: 18px; height: 1.5px; background: var(--gold); display: inline-block; }
.section-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3.8vw, 3.2rem); font-weight: 700; line-height: 1.1; color: var(--text); margin-bottom: 1.125rem; transition: color 0.4s; }
.section-title em { font-style: italic; color: var(--gold); }
.section-body { font-size: 1rem; font-weight: 300; color: var(--text-sub); line-height: 1.8; max-width: 580px; transition: color 0.4s; }

/* ─── MISSION ─── */
.mission-split { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 22px; overflow: hidden; border: 1px solid var(--border); transition: border-color 0.4s; }
.mission-img-col { position: relative; min-height: 480px; overflow: hidden; }
.mission-img-col img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; filter: var(--img-filter); transition: transform 0.6s ease, filter 0.4s; }
.mission-img-col:hover img { transform: scale(1.03); }
.mission-img-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(135deg, rgba(12,11,19,0.55) 0%, rgba(46,31,74,0.4) 100%); }
.mission-quote-over { position: absolute; bottom: 2rem; left: 2rem; right: 2rem; z-index: 2; }
.mission-quote-over blockquote { font-family: 'Playfair Display', serif; font-size: clamp(1.1rem, 1.8vw, 1.4rem); font-weight: 700; font-style: italic; color: #fff; line-height: 1.45; margin-bottom: 0.875rem; text-shadow: 0 1px 12px rgba(0,0,0,0.4); }
.mission-quote-over cite { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); font-style: normal; }
.mission-text-col { background: var(--bg-card); padding: 3.5rem; display: flex; flex-direction: column; justify-content: center; transition: background 0.4s; }

/* ─── STATS ─── */
.stats-band { background: #0C0B13; padding: 3rem 2rem; }
.stats-inner { max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
.stat-cell { background: #0C0B13; padding: 2rem 1.75rem; text-align: center; }
.stat-num { font-family: 'Playfair Display', serif; font-size: 2.6rem; font-weight: 900; color: var(--gold); line-height: 1; margin-bottom: 0.4rem; }
.stat-label { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(250,248,245,0.4); }

/* ─── HOW IT WORKS ─── */
.dark-section { background: #0C0B13; padding: 6rem 2rem; }
.dark-section .eyebrow { color: var(--gold); }
.dark-section .eyebrow::before { background: rgba(201,168,76,0.35); }
.dark-section .section-title { color: #FAF8F5; }
.steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.125rem; margin-top: 2.75rem; max-width: 1120px; margin-left: auto; margin-right: auto; }
.step-card { background: #1A0F2E; border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; padding: 2.25rem 1.875rem; transition: background 0.25s, border-color 0.25s, transform 0.2s; }
.step-card:hover { background: #2E1F4A; border-color: rgba(201,168,76,0.2); transform: translateY(-3px); }
.step-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); opacity: 0.65; margin-bottom: 0.875rem; }
.step-num { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 900; color: rgba(201,168,76,0.09); line-height: 1; margin-bottom: 1.125rem; }
.step-title { font-size: 1rem; font-weight: 600; color: #FAF8F5; margin-bottom: 0.625rem; line-height: 1.35; }
.step-body { font-size: 0.875rem; font-weight: 300; color: rgba(250,248,245,0.5); line-height: 1.75; }

/* ─── JAX ─── */
.jax-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 4.5rem; align-items: center; }
.listing-mosaic { display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem; }
.mosaic-card { border-radius: 14px; overflow: hidden; position: relative; border: 1px solid var(--border); transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s; cursor: default; }
.mosaic-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); border-color: var(--gold-border); }
.mosaic-card.tall { grid-row: span 2; }
.mosaic-card-img { width: 100%; height: 100%; min-height: 160px; display: block; object-fit: cover; filter: var(--img-filter); transition: transform 0.5s ease, filter 0.4s; }
.mosaic-card.tall .mosaic-card-img { min-height: 340px; }
.mosaic-card:hover .mosaic-card-img { transform: scale(1.04); }
.mosaic-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(12,11,19,0.88) 0%, rgba(12,11,19,0.1) 55%, transparent 100%); z-index: 1; }
.mosaic-card-info { position: absolute; bottom: 0; left: 0; right: 0; z-index: 2; padding: 1rem 1.125rem; }
.mosaic-card-name { font-size: 0.875rem; font-weight: 600; color: #fff; margin-bottom: 0.2rem; line-height: 1.25; }
.mosaic-card-meta { font-size: 0.7rem; color: rgba(255,255,255,0.55); }
.mosaic-badge { display: inline-block; margin-top: 0.4rem; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 100px; background: rgba(201,168,76,0.22); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }
.mosaic-badge.community { background: rgba(196,160,232,0.15); color: #C4A0E8; border-color: rgba(196,160,232,0.25); }

/* ─── PLATFORM CALLOUT ─── */
.platform-band { padding: 0 2rem 6rem; max-width: 1120px; margin: 0 auto; }
.platform-card { border-radius: 22px; overflow: hidden; display: grid; grid-template-columns: 1fr 1.1fr; min-height: 380px; border: 1px solid rgba(255,255,255,0.07); position: relative; }
.platform-img-col { position: relative; overflow: hidden; }
.platform-img-col img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; filter: brightness(0.55) saturate(0.75); transition: transform 0.5s ease; }
.platform-card:hover .platform-img-col img { transform: scale(1.03); }
.platform-img-col::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(26,15,46,0) 0%, #1A0F2E 100%); z-index: 1; }
.platform-text-col { background: #1A0F2E; padding: 3.5rem; display: flex; flex-direction: column; justify-content: center; position: relative; z-index: 1; }
.platform-card::after { content: 'VantaJax'; font-family: 'Playfair Display', serif; font-size: 8rem; font-weight: 900; color: rgba(201,168,76,0.04); position: absolute; right: 2rem; bottom: -1rem; line-height: 1; pointer-events: none; letter-spacing: -0.02em; z-index: 0; }
.platform-eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); opacity: 0.75; margin-bottom: 0.875rem; display: flex; align-items: center; gap: 0.6rem; }
.platform-eyebrow::before { content: ''; width: 18px; height: 1.5px; background: rgba(201,168,76,0.35); display: inline-block; }
.platform-title { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 2.5vw, 2.3rem); font-weight: 700; color: #fff; line-height: 1.15; margin-bottom: 1rem; position: relative; z-index: 1; }
.platform-body { font-size: 0.9rem; font-weight: 300; color: rgba(250,248,245,0.58); line-height: 1.8; max-width: 420px; position: relative; z-index: 1; }
.platform-link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.75rem; background: var(--gold); color: #0C0B13; font-size: 0.85rem; font-weight: 600; padding: 0.7rem 1.625rem; border-radius: 100px; text-decoration: none; transition: opacity 0.2s, transform 0.15s; position: relative; z-index: 1; }
.platform-link:hover { opacity: 0.88; transform: translateY(-2px); }
.platform-link svg { width: 13px; height: 13px; }

/* ─── VALUES ─── */
.values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.125rem; margin-top: 2.75rem; }
.value-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s, background 0.4s; }
.value-card:hover { transform: translateY(-3px); border-color: var(--gold-border); box-shadow: 0 8px 24px rgba(0,0,0,0.07); }
.value-card-body { padding: 1.75rem; }
.value-tag { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.11em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 0.5rem; transition: color 0.4s; }
[data-theme="dark"] .value-tag { color: var(--gold); }
.value-title { font-size: 0.975rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; line-height: 1.3; transition: color 0.4s; }
.value-body { font-size: 0.85rem; font-weight: 300; color: var(--text-sub); line-height: 1.75; transition: color 0.4s; }

/* ─── WAITLIST ─── */
.waitlist-section { position: relative; padding: 7rem 2rem; overflow: hidden; }
.waitlist-bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; filter: brightness(0.18) saturate(0.6); z-index: 0; }
[data-theme="light"] .waitlist-bg-img { filter: brightness(0.08) saturate(0.5); }
.waitlist-bg-overlay { position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(46,31,74,0.5) 0%, rgba(12,11,19,0.85) 100%); z-index: 1; }
.waitlist-inner { position: relative; z-index: 2; max-width: 620px; margin: 0 auto; text-align: center; }
.waitlist-inner .eyebrow { justify-content: center; color: var(--gold) !important; }
.waitlist-inner .eyebrow::before { display: none; }
.waitlist-inner .section-title { font-size: clamp(1.9rem, 3.5vw, 2.9rem); color: #fff !important; }
.waitlist-inner .section-body { margin: 0 auto 2.25rem; color: rgba(255,255,255,0.6) !important; max-width: 480px; }
.waitlist-form { display: flex; gap: 0.625rem; max-width: 460px; margin: 0 auto; }
.waitlist-input { flex: 1; padding: 0.8rem 1.25rem; font-family: 'DM Sans', sans-serif; font-size: 0.88rem; border: 1.5px solid rgba(255,255,255,0.2); border-radius: 100px; background: rgba(255,255,255,0.08); color: #fff; outline: none; transition: border-color 0.2s, box-shadow 0.2s; backdrop-filter: blur(8px); }
.waitlist-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,168,76,0.15); }
.waitlist-input::placeholder { color: rgba(255,255,255,0.35); }
.waitlist-note { font-size: 0.75rem; color: rgba(255,255,255,0.35); margin-top: 0.875rem; }
.waitlist-error { display: none; font-size: 0.8rem; color: #FCA5A5; margin-top: 0.625rem; }
.success-msg { display: none; background: rgba(201,168,76,0.15); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); border-radius: 12px; padding: 0.875rem 1.375rem; font-size: 0.875rem; font-weight: 500; margin-top: 1rem; }

/* ─── FOOTER ─── */
footer { background: #0C0B13; color: #FAF8F5; }
