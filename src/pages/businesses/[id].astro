---
import Layout from "../../layouts/Layout.astro";
import { supabase } from "../../lib/supabaseClient";
import { buildBusinessMeta } from "../../lib/seo";

const { id } = Astro.params;

const { data: business, error } = await supabase
  .from("businesses")
  .select("*")
  .eq("id", id)
  .single();

if (error) console.error("Error loading business:", error);

// Treat archived listings as not found for public visitors
const isArchived = (business as any)?.is_archived === true;

const safeUrl = (url: any) => {
  if (!url) return "";
  const trimmed = String(url).trim();
  if (!trimmed) return "";
  if (/^https?:\/\//i.test(trimmed)) return trimmed;
  return `https://${trimmed}`;
};

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";

// Support lat/lng, lat/lon, latitude/longitude column naming, and string or number values
const b = business as any;
const rawLat = b?.lat ?? b?.latitude;
const rawLng = b?.lng ?? b?.longitude ?? b?.lon;
const lat: number | null = rawLat != null ? parseFloat(String(rawLat)) : null;
const lng: number | null = rawLng != null ? parseFloat(String(rawLng)) : null;

// Privacy & type logic
const businessType: string = b?.business_type || "brick_and_mortar";
const isAddressPublic: boolean = b?.is_address_public !== false; // default true
const publicLocationLabel: string = b?.public_location_label || "";
const serviceArea: string = b?.service_area || "";
const isOnlineOnly = businessType === "online_only";
const isServiceBased = businessType === "service_based";

// Address: only show if public and not online/service-based
const showAddress = isAddressPublic && !isOnlineOnly && !isServiceBased;

const fullAddress = business && showAddress
  ? [
      business.address,
      [business.city, business.state].filter(Boolean).join(", "),
      business.zip,
    ]
      .filter(Boolean)
      .join(" ")
  : "";

// Display location for non-public or non-storefront
const displayLocation = (() => {
  if (isOnlineOnly) return null;
  if (isServiceBased) {
    if (serviceArea) return `Serves: ${serviceArea}`;
    if (publicLocationLabel) return publicLocationLabel;
    return "Jacksonville, FL area";
  }
  if (!isAddressPublic) return publicLocationLabel || null;
  return null; // fullAddress handles this case
})();

const mapsUrl = fullAddress
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(fullAddress)}`
  : "";

// No map for online_only; service_based uses stored zip centroid coords
const hasCoords = !isOnlineOnly && lat != null && !isNaN(lat) && lng != null && !isNaN(lng);

// Hours of operation
type DayHours = { open: string | null; close: string | null; closed: boolean };
const hoursData: Record<string, DayHours> | null = b?.hours ?? null;

const dayOrder = ["monday","tuesday","wednesday","thursday","friday","saturday","sunday"];
const dayLabels: Record<string, string> = {
  monday: "Mon", tuesday: "Tue", wednesday: "Wed", thursday: "Thu",
  friday: "Fri", saturday: "Sat", sunday: "Sun",
};
// JS day: 0=Sun, 1=Mon...
const jsDayToKey = ["sunday","monday","tuesday","wednesday","thursday","friday","saturday"];
const todayKey = jsDayToKey[new Date().getDay()];

function fmtTime(t: string | null): string {
  if (!t) return "";
  const [hStr, mStr] = t.split(":");
  const h = parseInt(hStr, 10);
  const m = parseInt(mStr, 10);
  const ampm = h >= 12 ? "pm" : "am";
  const h12 = h % 12 || 12;
  return m > 0 ? `${h12}:${mStr}${ampm}` : `${h12}${ampm}`;
}

// Social links
const instagramUrl = b?.instagram_url ? String(b.instagram_url).trim() : "";
const facebookUrl = b?.facebook_url ? String(b.facebook_url).trim() : "";
const tiktokUrl = b?.tiktok_url ? String(b.tiktok_url).trim() : "";
const hasSocial = instagramUrl || facebookUrl || tiktokUrl;

// Logo support
const logoUrl = business?.logo_url ? String(business.logo_url).trim() : "";
const initials = business?.name
  ? business.name
      .split(" ")
      .filter(Boolean)
      .slice(0, 2)
      .map((w: string) => w[0]?.toUpperCase())
      .join("")
  : "-";

// Ownership
const isClaimed: boolean = b?.is_claimed === true;

const seoMeta = business && !isArchived
  ? buildBusinessMeta({
      name: business.name,
      category: business.category ?? 'other',
      city: business.city ?? '',
      state: business.state ?? '',
      description: business.description ?? null,
      logo_url: business.logo_url ?? null,
      id: business.id,
    })
  : null;
---

<Layout title={seoMeta ? seoMeta.title : (business ? business.name : "Business • VantaJax")}>
  {seoMeta && (
    <Fragment slot="head">
      <meta name="description" content={seoMeta.description} />
      <link rel="canonical" href={seoMeta.canonicalUrl} />
      <meta property="og:type" content="website" />
      <meta property="og:title" content={seoMeta.title} />
      <meta property="og:description" content={seoMeta.description} />
      <meta property="og:url" content={seoMeta.canonicalUrl} />
      <meta property="og:image" content={`https://vantajax.com/api/og/${business.id}`} />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={seoMeta.title} />
      <meta name="twitter:description" content={seoMeta.description} />
      <meta name="twitter:image" content={`https://vantajax.com/api/og/${business.id}`} />
      <script type="application/ld+json" set:html={JSON.stringify(seoMeta.jsonLd)} />
    </Fragment>
  )}
  <main class="min-h-[70vh] bg-white">
    {isArchived ? (
      <section class="px-4 py-16">
        <div class="mx-auto max-w-2xl rounded-[28px] border border-slate-200 bg-white p-8 text-center shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500">
            Unavailable
          </p>
          <h1 class="mt-2 text-2xl font-semibold text-slate-900">
            This listing is no longer available.
          </h1>
          <p class="mt-2 text-[12px] text-slate-600">
            This page is no longer accessible. Browse the directory to find other businesses.
          </p>
          <a
            href="/businesses"
            class="mt-6 inline-flex items-center justify-center rounded-2xl bg-[#C9A84C] px-5 py-3 text-[13px] font-semibold text-[#0E0C0A] shadow-[0_16px_34px_-22px_rgba(201,168,76,0.35)] transition hover:-translate-y-0.5 hover:bg-[#8B6914] hover:text-[#FAF8F5]"
          >
            Browse the directory
          </a>
        </div>
      </section>
    ) : business ? (
      <section class="px-4 pt-12 pb-16">
        <div class="mx-auto w-full max-w-[1100px] space-y-6">
          <!-- Top nav -->
          <div class="flex flex-wrap items-center justify-between gap-3">
            <a
              href="/businesses"
              class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-[12px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
            >
              ← Back to search
            </a>

            <div class="flex flex-wrap items-center gap-2">
              {business.verified && (
                <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold text-emerald-700 shadow-sm">
                  Verified
                </span>
              )}
              {business.featured && (
                <span class="inline-flex items-center rounded-full border border-[rgba(201,168,76,0.35)] bg-[#FDF6E3] px-3 py-1 text-[11px] font-semibold text-[#8B6914] shadow-sm">
                  Featured
                </span>
              )}
              {business.woman_owned && (
                <span class="vj-badge-woman-owned shadow-sm">
                  Woman-Owned
                </span>
              )}
            </div>
          </div>

          <!-- Hero -->
          <header class="rounded-[28px] border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
              <div class="min-w-0">
                <!-- ✅ Name row with logo -->
                <div class="flex items-center gap-4">
                  <div class="h-14 w-14 shrink-0 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                    {logoUrl ? (
                      <img
                        src={logoUrl}
                        alt={`${business.name} logo`}
                        class="h-full w-full object-contain p-2"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="h-full w-full grid place-items-center text-[14px] font-semibold text-slate-700">
                        {initials}
                      </div>
                    )}
                  </div>

                  <div class="min-w-0">
                    <h1 class="min-w-0 text-2xl sm:text-4xl font-bold tracking-tight text-slate-900" style="font-family: 'Playfair Display', serif;">
                      {business.name}
                    </h1>
                    {isClaimed && (
                      <p class="mt-1 text-[11px] text-slate-400 flex items-center gap-1">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                        </svg>
                        Managed by owner
                      </p>
                    )}
                  </div>
                </div>

                <div class="mt-3 flex flex-wrap items-center gap-2 text-[12px] text-slate-600">
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1 shadow-sm capitalize">
                    {business.category}
                  </span>

                  {(business.city || business.state) && (
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 shadow-sm">
                      {[business.city, business.state].filter(Boolean).join(", ")}
                    </span>
                  )}

                  {business.area && (
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 shadow-sm">
                      Serving: {business.area}
                    </span>
                  )}
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-2">
                <button
                  id="copy-link"
                  class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-[12px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
                >
                  Copy link
                </button>
              </div>
            </div>

            {business.description && (
              <div class="mt-6 space-y-2">
                <h2 class="text-xs font-medium tracking-wide text-slate-400">
                  About
                </h2>
                <p class="text-[13px] leading-relaxed text-slate-700">
                  {business.description}
                </p>
              </div>
            )}
          </header>

          <!-- Content grid -->
          <div class="grid gap-6 lg:grid-cols-3">
            <!-- Left: details -->
            <div class="space-y-6 lg:col-span-2">
              <section class="rounded-[28px] border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
                <h2 class="text-xs font-medium tracking-wide text-slate-400">
                  Details
                </h2>

                <div class="mt-5 divide-y divide-slate-200">
                  <div class="flex items-start justify-between gap-3 py-3">
                    <div class="flex items-center gap-2">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="shrink-0 text-slate-400" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.73 12 19.79 19.79 0 0 1 1.67 3.4 2 2 0 0 1 3.66 1.25h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.89a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.34 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="text-[12px] font-semibold text-slate-900">Phone</span>
                    </div>
                    {business.phone ? (
                      <a
                        href={`tel:${business.phone}`}
                        class="text-[12px] font-semibold text-[#8B6914] underline underline-offset-2 hover:text-[#5C4100]"
                      >
                        {business.phone}
                      </a>
                    ) : (
                      <span class="text-[12px] text-slate-500">Not provided</span>
                    )}
                  </div>

                  <div class="flex items-start justify-between gap-3 py-3">
                    <div class="flex items-center gap-2">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="shrink-0 text-slate-400" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.75"/>
                        <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="text-[12px] font-semibold text-slate-900">Website</span>
                    </div>
                    {business.website ? (
                      <a
                        href={safeUrl(business.website)}
                        target="_blank"
                        rel="noreferrer"
                        class="text-[12px] font-semibold text-[#8B6914] underline underline-offset-2 hover:text-[#5C4100]"
                      >
                        Visit
                      </a>
                    ) : (
                      <span class="text-[12px] text-slate-500">Not provided</span>
                    )}
                  </div>

                  {hasSocial && (
                    <div class="flex items-center justify-between gap-3 py-3">
                      <div class="flex items-center gap-2">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="shrink-0 text-slate-400" aria-hidden="true">
                          <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75"/>
                          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/>
                          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                        </svg>
                        <span class="text-[12px] font-semibold text-slate-900">Social</span>
                      </div>
                      <div class="flex items-center gap-3">
                        {instagramUrl && (
                          <a href={safeUrl(instagramUrl)} target="_blank" rel="noreferrer" aria-label="Instagram" class="text-slate-500 hover:text-pink-600 transition">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75"/>
                              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/>
                              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                            </svg>
                          </a>
                        )}
                        {facebookUrl && (
                          <a href={safeUrl(facebookUrl)} target="_blank" rel="noreferrer" aria-label="Facebook" class="text-slate-500 hover:text-blue-600 transition">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </a>
                        )}
                        {tiktokUrl && (
                          <a href={safeUrl(tiktokUrl)} target="_blank" rel="noreferrer" aria-label="TikTok" class="text-slate-500 hover:text-slate-900 transition">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </a>
                        )}
                      </div>
                    </div>
                  )}

                </div>
              </section>

              {/* Hours of Operation */}
              {hoursData && (
                <section class="rounded-[28px] border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
                  <h2 class="text-xs font-medium tracking-wide text-slate-400">Hours</h2>

                  {(() => {
                    const todayHours = hoursData[todayKey];
                    return todayHours ? (
                      <div class="mt-3 mb-5 rounded-2xl border border-[rgba(201,168,76,0.25)] bg-[rgba(253,246,227,0.7)] px-4 py-3">
                        {todayHours.closed ? (
                          <p class="text-[13px] font-semibold text-slate-700">Closed today</p>
                        ) : (
                          <p class="text-[13px] font-semibold text-slate-700">
                            Open today · {fmtTime(todayHours.open)}–{fmtTime(todayHours.close)}
                          </p>
                        )}
                      </div>
                    ) : null;
                  })()}

                  <div class="divide-y divide-slate-100">
                    {dayOrder.map((day) => {
                      const dh = hoursData[day];
                      if (!dh) return null;
                      const isToday = day === todayKey;
                      return (
                        <div class={`flex items-center justify-between py-2 ${isToday ? "font-semibold" : ""}`}>
                          <span class={`text-[12px] w-10 ${isToday ? "text-[#8B6914]" : "text-slate-500"}`}>
                            {dayLabels[day]}
                          </span>
                          {dh.closed ? (
                            <span class="text-[12px] text-slate-400">Closed</span>
                          ) : (
                            <span class={`text-[12px] ${isToday ? "text-slate-900" : "text-slate-700"}`}>
                              {fmtTime(dh.open)}–{fmtTime(dh.close)}
                            </span>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </section>
              )}

              <!-- Map section: only render when there's something to show -->
              {(hasCoords && mapboxToken) || fullAddress ? (
                <section class="rounded-[28px] border border-slate-200/70 bg-white/70 overflow-hidden shadow-[0_18px_48px_-40px_rgba(2,6,23,0.7)]">
                  {hasCoords && mapboxToken ? (
                    <div
                      id="business-map"
                      data-lat={lat}
                      data-lng={lng}
                      data-name={business.name}
                      data-token={mapboxToken}
                      style="height: 260px; width: 100%;"
                    />
                  ) : (
                    <div class="p-6 sm:p-8">
                      <h2 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-500">
                        Location
                      </h2>
                      <p class="mt-3 text-[13px] text-slate-700">{fullAddress}</p>
                      <a
                        href={mapsUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="mt-4 inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#8B6914] underline underline-offset-2 hover:text-[#5C4100]"
                      >
                        View on Google Maps →
                      </a>
                    </div>
                  )}
                </section>
              ) : null}

              <section class="rounded-[28px] border border-slate-200/70 bg-white/70 p-6 sm:p-8 shadow-[0_18px_48px_-40px_rgba(2,6,23,0.7)] backdrop-blur">
                <h2 class="text-xs font-medium tracking-wide text-slate-400">
                  Community note
                </h2>
                <p class="mt-3 text-[13px] leading-relaxed text-slate-700">
                  VantaJax highlights Black-owned businesses and professionals to help the community discover, support, and circulate dollars locally.
                </p>
              </section>

              <!-- Suggest an edit CTA -->
              <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-xs font-medium tracking-wide text-slate-400">Know something we don't?</h2>
                <p class="mt-2 text-[13px] text-slate-600 leading-relaxed">
                  Help keep this listing accurate — hours, address changes, new website, or anything else.
                </p>
                <a
                  href={`/suggest-business?ref=${id}`}
                  class="mt-4 inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-[12px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
                >
                  Suggest an edit
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </section>
            </div>

            <!-- Right: actions -->
            <aside class="lg:col-span-1">
              <div class="space-y-6 lg:sticky lg:top-24">
                <section class="rounded-[28px] border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
                  <h2 class="text-xs font-medium tracking-wide text-slate-400">
                    Actions
                  </h2>

                  <div class="mt-4 grid gap-3">
                    {fullAddress && !isOnlineOnly ? (
                      <a
                        id="open-in-maps"
                        href={mapsUrl}
                        data-address={fullAddress}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center justify-center rounded-2xl bg-[#C9A84C] px-4 py-3 text-[13px] font-semibold text-[#0E0C0A] shadow-[0_16px_34px_-22px_rgba(201,168,76,0.35)] transition hover:-translate-y-0.5 hover:bg-[#8B6914] hover:text-[#FAF8F5]"
                      >
                        Directions
                      </a>
                    ) : !isOnlineOnly ? (
                      <button
                        class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-500 shadow-sm"
                        disabled
                      >
                        Directions unavailable
                      </button>
                    ) : null}

                    {business.website ? (
                      <a
                        href={safeUrl(business.website)}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
                      >
                        Website
                      </a>
                    ) : null}

                    {business.phone ? (
                      <a
                        href={`tel:${business.phone}`}
                        class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
                      >
                        Call
                      </a>
                    ) : null}

                    <button
                      id="share"
                      class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5"
                    >
                      Share
                    </button>
                  </div>

                  <p class=”mt-4 text-[11px] text-slate-500 leading-relaxed”>
                    Tip: If a link doesn’t open correctly on mobile, try “Copy link” and paste into your browser.
                  </p>

                </section>
              </div>
            </aside>
          </div>

          <!-- Claim banner (unclaimed only) -->
          {!isClaimed && (
            <div class="rounded-[20px] border border-[rgba(201,168,76,0.35)] bg-[#FDF6E3] px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <div>
                <p class="text-[13px] font-semibold text-[#5C4100]">Is this your business?</p>
                <p class="text-[12px] text-[#8B6914] mt-0.5">Claim this listing to manage your info, add a logo, and more.</p>
              </div>
              <a href={`/claim/${business.id}`} class="claim-cta" style="width:auto; white-space:nowrap; margin-top:0;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Claim this listing →
              </a>
            </div>
          )}
        </div>

        <!-- Mapbox GL JS map init -->
        <script is:inline>
          (function () {
            const el = document.getElementById('business-map');
            if (!el) return;
            const lat = parseFloat(el.dataset.lat || '');
            const lng = parseFloat(el.dataset.lng || '');
            const token = el.dataset.token || '';
            const name = el.dataset.name || '';
            if (!token || isNaN(lat) || isNaN(lng)) return;

            const css = document.createElement('link');
            css.rel = 'stylesheet';
            css.href = 'https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css';
            document.head.appendChild(css);

            const s = document.createElement('script');
            s.src = 'https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js';
            s.onload = function () {
              mapboxgl.accessToken = token;
              const map = new mapboxgl.Map({
                container: el,
                style: 'mapbox://styles/mapbox/light-v11',
                center: [lng, lat],
                zoom: 15,
                interactive: true,
              });
              new mapboxgl.Marker({ color: '#C9A84C' })
                .setLngLat([lng, lat])
                .setPopup(new mapboxgl.Popup({ offset: 25 }).setText(name))
                .addTo(map);
            };
            document.head.appendChild(s);
          })();
        </script>

        <!-- View count ping (fire-and-forget) -->
        <script is:inline define:vars={{ businessId: business?.id }}>
          if (businessId) {
            fetch('/api/view', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ businessId }),
            }).catch(() => {});
          }
        </script>

        <!-- Keep your deep-link behavior + copy/share -->
        <script is:inline>
          (function () {
            const copyBtn = document.getElementById('copy-link');
            if (copyBtn) {
              copyBtn.addEventListener('click', async function () {
                try {
                  await navigator.clipboard.writeText(window.location.href);
                  copyBtn.textContent = 'Copied';
                  setTimeout(() => (copyBtn.textContent = 'Copy link'), 1200);
                } catch (e) {
                  copyBtn.textContent = 'Copy failed';
                  setTimeout(() => (copyBtn.textContent = 'Copy link'), 1200);
                }
              });
            }

            const shareBtn = document.getElementById('share');
            if (shareBtn) {
              shareBtn.addEventListener('click', async function () {
                const data = { title: document.title, url: window.location.href };
                try {
                  if (navigator.share) {
                    await navigator.share(data);
                  } else if (navigator.clipboard) {
                    await navigator.clipboard.writeText(window.location.href);
                    shareBtn.textContent = 'Copied';
                    setTimeout(() => (shareBtn.textContent = 'Share'), 1200);
                  }
                } catch (e) {}
              });
            }

            function wireMaps(id) {
              const link = document.getElementById(id);
              if (!link) return;

              link.addEventListener('click', function (event) {
                const address = link.getAttribute('data-address') || '';
                if (!navigator || !navigator.userAgent) return;

                const ua = navigator.userAgent.toLowerCase();
                const isIOS = /iphone|ipad|ipod/.test(ua) && !window.MSStream;
                const isAndroid = /android/.test(ua);

                if (isIOS) {
                  event.preventDefault();
                  window.location.href = 'maps://?q=' + encodeURIComponent(address);
                } else if (isAndroid) {
                  event.preventDefault();
                  window.location.href = 'geo:0,0?q=' + encodeURIComponent(address);
                }
              });
            }

            wireMaps('open-in-maps');
          })();
        </script>
      </section>
    ) : (
      <section class="px-4 py-16">
        <div class="mx-auto max-w-2xl rounded-[28px] border border-slate-200 bg-white p-8 text-center shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500">
            Not found
          </p>
          <h1 class="mt-2 text-2xl font-semibold text-slate-900">
            Business not found
          </h1>
          <p class="mt-2 text-[12px] text-slate-600">
            The listing you’re looking for may have been removed or the link may be incorrect.
          </p>
          <a
            href="/businesses"
            class="mt-6 inline-flex items-center justify-center rounded-2xl bg-[#C9A84C] px-5 py-3 text-[13px] font-semibold text-[#0E0C0A] shadow-[0_16px_34px_-22px_rgba(201,168,76,0.35)] transition hover:-translate-y-0.5 hover:bg-[#8B6914] hover:text-[#FAF8F5]"
          >
            Back to search
          </a>
        </div>
      </section>
    )}
  </main>
</Layout>
