---
import Layout from "../layouts/Layout.astro";

const email = Astro.url.searchParams.get("email") ?? "";
---

<Layout title="Unsubscribed — VantaJax" description="You've been unsubscribed from VantaJax emails.">
  <div class="unsubscribe-wrap">
    <div class="unsubscribe-card">
      <div class="wordmark">Vanta<span>Jax</span></div>
      <div class="icon" aria-hidden="true">✓</div>
      <h1>You're unsubscribed</h1>
      {email && <p class="email-line">{email}</p>}
      <p class="body">You won't receive any more emails from VantaJax. If this was a mistake, you can re-subscribe any time from the <a href="/">homepage</a>.</p>
      <a href="/businesses" class="cta">Browse the directory →</a>
    </div>
  </div>
</Layout>

<style>
  .unsubscribe-wrap {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .unsubscribe-card {
    max-width: 440px;
    width: 100%;
    text-align: center;
    background: var(--bg-secondary, #fff);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 16px;
    padding: 3rem 2.5rem;
  }
  .wordmark {
    font-family: Georgia, serif;
    font-size: 1.1rem;
    color: #7C3AED;
    margin-bottom: 1.75rem;
  }
  .wordmark span { color: #1C1C1C; }
  .icon {
    width: 48px;
    height: 48px;
    background: #D1FAE5;
    color: #047857;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }
  h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary, #1C1C1C);
    margin-bottom: 0.5rem;
  }
  .email-line {
    font-size: 0.85rem;
    color: #6B7280;
    margin-bottom: 1rem;
  }
  .body {
    font-size: 0.9rem;
    color: #6B7280;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }
  .body a {
    color: #7C3AED;
    text-decoration: none;
  }
  .cta {
    display: inline-block;
    background: #7C3AED;
    color: #fff;
    text-decoration: none;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .cta:hover { opacity: 0.85; }
</style>
