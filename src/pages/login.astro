---
import Layout from "../layouts/Layout.astro";
import { createSupabaseServerClient } from "../lib/supabaseServer";

export const prerender = false;

const supabase = createSupabaseServerClient(Astro);
const { data: { session } } = await supabase.auth.getSession();
const nextParam = Astro.url.searchParams.get("next") || "/dashboard";

if (session) {
  return Astro.redirect(nextParam);
}
---

<Layout title="Sign in • VantaJax">
  <!-- Pass server values to client script via data attrs -->
  <div
    id="login-config"
    data-next={nextParam}
    style="display:none"
  ></div>

  <div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-6">

      <!-- Header -->
      <div class="text-center">
        <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-[#8B6914]">VantaJax</p>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">Sign in to your account</h1>
        <p class="mt-2 text-[13px] text-slate-500">
          For business owners claiming or managing their listing.
        </p>
      </div>

      <!-- Card -->
      <div class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-sm space-y-5">

        <!-- Google OAuth -->
        <button
          id="google-btn"
          type="button"
          class="w-full inline-flex items-center justify-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-50"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>

        <!-- Divider -->
        <div class="flex items-center gap-3">
          <div class="h-px flex-1 bg-slate-200"></div>
          <span class="text-[11px] text-slate-400">or</span>
          <div class="h-px flex-1 bg-slate-200"></div>
        </div>

        <!-- Magic link form -->
        <form id="magic-link-form" class="space-y-3">
          <div>
            <label for="email" class="block text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mb-1.5">
              Email address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] text-slate-900 placeholder:text-slate-400 shadow-sm transition focus:outline-none focus:ring-2 focus:ring-[rgba(201,168,76,0.4)]"
            />
          </div>
          <button
            type="submit"
            id="magic-link-btn"
            class="w-full inline-flex items-center justify-center rounded-2xl bg-[#C9A84C] px-4 py-3 text-[13px] font-semibold text-[#0E0C0A] shadow-[0_14px_30px_-20px_rgba(201,168,76,0.55)] transition hover:-translate-y-0.5 hover:bg-[#8B6914] hover:text-[#FAF8F5] disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Send magic link
          </button>
        </form>

        <!-- Status messages -->
        <div id="status-msg" class="hidden rounded-2xl border px-4 py-3 text-[12px] font-medium"></div>

      </div>

      <!-- Footer note -->
      <p class="text-center text-[11px] text-slate-400">
        No password needed. Magic links expire after 1 hour.
      </p>

    </div>
  </div>
</Layout>

<script>
  // createBrowserClient uses PKCE flow and stores session in cookies
  // (readable by the server middleware + dashboard SSR check)
  import { createBrowserClient } from "@supabase/ssr";

  const config = document.getElementById("login-config") as HTMLElement;
  const nextParam = config?.dataset.next || "/dashboard";
  const CALLBACK_URL = `${window.location.origin}/auth/callback?next=${encodeURIComponent(nextParam)}`;

  const supabase = createBrowserClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const statusEl = document.getElementById("status-msg") as HTMLElement;

  function showStatus(msg: string, isError = false) {
    statusEl.textContent = msg;
    statusEl.className = `rounded-2xl border px-4 py-3 text-[12px] font-medium ${
      isError
        ? "border-red-200 bg-red-50 text-red-700"
        : "border-emerald-200 bg-emerald-50 text-emerald-700"
    }`;
  }

  // Google OAuth
  document.getElementById("google-btn")?.addEventListener("click", async () => {
    const { error } = await supabase.auth.signInWithOAuth({
      provider: "google",
      options: { redirectTo: CALLBACK_URL },
    });
    if (error) showStatus(error.message, true);
  });

  // Magic link
  document.getElementById("magic-link-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const emailEl = document.getElementById("email") as HTMLInputElement;
    const email = emailEl.value.trim();
    if (!email) return;

    const btn = document.getElementById("magic-link-btn") as HTMLButtonElement;
    btn.textContent = "Sending…";
    btn.disabled = true;

    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: CALLBACK_URL },
    });

    if (error) {
      showStatus(error.message, true);
      btn.textContent = "Send magic link";
      btn.disabled = false;
    } else {
      showStatus(`Check your inbox — we sent a link to ${email}`);
      btn.textContent = "Link sent ✓";
    }
  });
</script>
