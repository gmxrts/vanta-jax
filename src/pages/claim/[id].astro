---
import Layout from "../../layouts/Layout.astro";
import { createSupabaseServerClient } from "../../lib/supabaseServer";

export const prerender = false;

const supabase = createSupabaseServerClient(Astro);
const { id } = Astro.params;

// Fetch business
const { data: business } = await supabase
  .from("businesses")
  .select("id, name, category, city, state, address, is_address_public, business_type, is_claimed")
  .eq("id", id)
  .single();

if (!business) {
  return Astro.redirect("/businesses");
}

// Get current session
const { data: { session } } = await supabase.auth.getSession();

// If logged in, check for existing claim
let existingClaim: { status: string } | null = null;
if (session) {
  const { data } = await supabase
    .from("business_claims")
    .select("status")
    .eq("business_id", id)
    .eq("user_id", session.user.id)
    .maybeSingle();
  existingClaim = data;
}

const isAlreadyClaimed = business.is_claimed;
const locationLabel = business.is_address_public && business.business_type !== "online_only" && business.business_type !== "service_based"
  ? [business.address, business.city, business.state].filter(Boolean).join(", ")
  : business.city
    ? `${business.city}${business.state ? `, ${business.state}` : ""}`
    : "Jacksonville, FL";
---

<Layout title={`Claim ${business.name} • VantaJax`}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-6">

      <!-- Business info -->
      <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">Claiming</p>
        <h1 class="mt-1 text-xl font-bold text-slate-900">{business.name}</h1>
        {locationLabel && (
          <p class="mt-1 text-[12px] text-slate-500">{locationLabel}</p>
        )}
        {business.category && (
          <span class="mt-3 inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-500">
            {business.category}
          </span>
        )}
      </div>

      <!-- Main content -->
      {isAlreadyClaimed ? (
        <!-- Already claimed -->
        <div class="rounded-[28px] border border-amber-200 bg-amber-50 p-6 shadow-sm text-center">
          <p class="text-[13px] font-semibold text-amber-800">This listing has already been claimed.</p>
          <p class="mt-2 text-[12px] text-amber-700">If you believe this is an error, contact us at vantajacksonville@gmail.com.</p>
          <a href={`/businesses/${business.id}`} class="mt-4 inline-flex items-center gap-1 text-[12px] font-semibold text-slate-700 hover:text-purple-700">
            ← Back to listing
          </a>
        </div>
      ) : existingClaim ? (
        <!-- Existing claim status -->
        <div class={`rounded-[28px] border p-6 shadow-sm text-center ${
          existingClaim.status === "pending"
            ? "border-purple-200 bg-purple-50"
            : existingClaim.status === "approved"
              ? "border-emerald-200 bg-emerald-50"
              : "border-red-200 bg-red-50"
        }`}>
          {existingClaim.status === "pending" && (
            <>
              <p class="text-[13px] font-semibold text-purple-800">Your claim is under review.</p>
              <p class="mt-2 text-[12px] text-purple-700">We'll notify you at {session?.user.email} once it's approved.</p>
              <a href="/dashboard" class="mt-4 inline-block text-[12px] font-semibold text-purple-700 hover:text-purple-900">
                Go to dashboard →
              </a>
            </>
          )}
          {existingClaim.status === "approved" && (
            <>
              <p class="text-[13px] font-semibold text-emerald-800">Claim approved! You own this listing.</p>
              <a href="/dashboard" class="mt-4 inline-block text-[12px] font-semibold text-emerald-700 hover:text-emerald-900">
                Go to dashboard →
              </a>
            </>
          )}
          {existingClaim.status === "rejected" && (
            <>
              <p class="text-[13px] font-semibold text-red-800">Your claim was not approved.</p>
              <p class="mt-2 text-[12px] text-red-700">Contact vantajacksonville@gmail.com for more information.</p>
            </>
          )}
        </div>
      ) : session ? (
        <!-- Logged in — show submit form -->
        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm space-y-5">
          <div>
            <h2 class="text-base font-semibold text-slate-900">Submit your claim</h2>
            <p class="mt-1 text-[12px] text-slate-500">
              Signed in as <span class="font-medium text-slate-700">{session.user.email}</span>.
              All claims are reviewed manually — you'll be notified when approved.
            </p>
          </div>

          <div id="claim-status" class="hidden rounded-2xl border px-4 py-3 text-[12px] font-medium"></div>

          <div class="flex flex-col gap-2 sm:flex-row">
            <button
              id="submit-claim-btn"
              type="button"
              class="flex-1 inline-flex items-center justify-center rounded-2xl bg-purple-600 px-4 py-3 text-[13px] font-semibold text-white shadow-[0_14px_30px_-20px_rgba(147,51,234,0.55)] transition hover:-translate-y-0.5 hover:bg-purple-700 disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Claim this listing
            </button>
            <a
              href={`/businesses/${business.id}`}
              class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-[13px] font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5"
            >
              Cancel
            </a>
          </div>

          <p class="text-[11px] text-slate-400">
            By claiming this listing, you agree to our <a href="/terms" class="underline underline-offset-2 hover:text-slate-600">Terms of Service</a> and <a href="/privacy" class="underline underline-offset-2 hover:text-slate-600">Privacy Policy</a>.
          </p>
        </div>
      ) : (
        <!-- Not logged in — show auth options -->
        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm space-y-4">
          <div>
            <h2 class="text-base font-semibold text-slate-900">Verify your identity</h2>
            <p class="mt-1 text-[12px] text-slate-500">
              Sign in to submit your claim. No password required.
            </p>
          </div>

          <a
            href={`/login?next=${encodeURIComponent(`/claim/${business.id}`)}`}
            class="w-full inline-flex items-center justify-center rounded-2xl bg-purple-600 px-4 py-3 text-[13px] font-semibold text-white shadow-[0_14px_30px_-20px_rgba(147,51,234,0.55)] transition hover:-translate-y-0.5 hover:bg-purple-700"
          >
            Sign in to claim
          </a>

          <p class="text-[11px] text-slate-400 text-center">
            Magic link or Google — your choice.
          </p>
        </div>
      )}

      <div class="text-center">
        <a href={`/businesses/${business.id}`} class="text-[11px] text-slate-400 hover:text-slate-600">
          ← Back to {business.name}
        </a>
      </div>

    </div>
  </div>
</Layout>

{session && !existingClaim && !isAlreadyClaimed && (
  <script define:vars={{ businessId: business.id }}>
    const btn = document.getElementById("submit-claim-btn");
    const statusEl = document.getElementById("claim-status");

    function showStatus(msg, isError = false) {
      statusEl.textContent = msg;
      statusEl.className = `rounded-2xl border px-4 py-3 text-[12px] font-medium ${
        isError
          ? "border-red-200 bg-red-50 text-red-700"
          : "border-emerald-200 bg-emerald-50 text-emerald-700"
      }`;
    }

    btn?.addEventListener("click", async () => {
      btn.disabled = true;
      btn.textContent = "Submitting…";

      try {
        const res = await fetch("/api/claim", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ businessId }),
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          showStatus(data?.error || "Something went wrong.", true);
          btn.disabled = false;
          btn.textContent = "Claim this listing";
        } else {
          showStatus("Claim submitted! We'll review it and notify you by email.");
          btn.textContent = "Claim submitted ✓";
        }
      } catch {
        showStatus("Network error — please try again.", true);
        btn.disabled = false;
        btn.textContent = "Claim this listing";
      }
    });
  </script>
)}
